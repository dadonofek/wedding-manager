{
  "name": "wedding-manager-dev",
  "private": true,
  "description": "Dev tooling: Apps Script logic tests + RSVP form e2e tests + demo media",
  "type": "module",
  "scripts": {
    "render": "node e2e/render.mjs",
    "test:gas": "node --test tests/gas/*.test.mjs",
